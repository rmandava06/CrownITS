# GitHub Personal Access Token (repo write access)
# Create at: https://github.com/settings/tokens/new
# Required scopes: repo (full control)
VITE_GITHUB_TOKEN=<token>

# Web3Forms access key for contact & job application emails
# Sign up free at: https://web3forms.com/
# Set the notification email to hr@crownits.com in the Web3Forms dashboard
VITE_WEB3FORMS_ACCESS_KEY=your_web3forms_access_key_here

# Optional: override recipient email (defaults to hr@crownits.com)
# VITE_CONTACT_EMAIL=hr@crownits.com

# Optional overrides (defaults to rmandava06/CrownITS/main)
# VITE_GITHUB_OWNER=rmandava06
# VITE_GITHUB_REPO=CrownITS
# VITE_GITHUB_BRANCH=main
